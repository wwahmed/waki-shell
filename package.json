{
  "name": "waki-shell",
  "version": "0.2.0",
  "private": true,
  "description": "Shared shell scaffolding (Header, Splash, UpdateBanner, UserMenu, state components) plus a layer-1 JSON config bundle for Waqas's apps. Consumed by printer-dashboard and waki-brain via the dist/shell.json contract.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node --import tsx scripts/build-shell-json.ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles/animations.css": "./src/styles/animations.css",
    "./styles/utilities.css": "./src/styles/utilities.css",
    "./styles/dark-mode-safety.css": "./src/styles/dark-mode-safety.css",
    "./styles/index.css": "./src/styles/index.css",
    "./tailwind.config.shared.js": "./tailwind.config.shared.js",
    "./templates/theme-bootstrap.html": "./templates/theme-bootstrap.html",
    "./vite/version-plugin": "./src/vite/version-plugin.ts"
  },
  "keywords": [
    "shell",
    "scaffolding",
    "react",
    "tailwind",
    "design-system"
  ],
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.8"
  },
  "peerDependencies": {
    "react": "^18.3.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  }
}
